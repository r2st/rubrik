# ============================================================================
# Transcript Intelligence — environment configuration
# Copy to `.env` and adjust. Never commit `.env` (it's gitignored).
# ============================================================================

# ----------------------------------------------------------------- environment
ENV=dev                       # dev | staging | prod

# ---------------------------------------------------------------------- logging
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text               # text | json (use 'json' in prod)

# -------------------------------------------------------------------------- API
# When API_KEY is set, all /api/* endpoints require an X-API-Key header.
# Leave empty for an open dev environment.
API_KEY=

# Comma-separated list of allowed CORS origins. Use exact domains in prod.
# CORS_ORIGINS=["https://dashboard.example.com"]
CORS_ORIGINS=["*"]

# Rate limits per remote IP (slowapi syntax)
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_STRICT=30/minute

# --------------------------------------------------------------------- pipeline
# Override the dataset path (must contain meeting subdirectories with JSON files)
# DATASET_PATH=/path/to/dataset

# Rebuild the pipeline every N minutes. 0 = no refresh (state is built once at
# startup). Recommended in prod when the dataset can change underneath us.
PIPELINE_REFRESH_MINUTES=0

# ---------------------------------------------------------------- observability
METRICS_ENABLED=true

# Sentry — leave empty to disable error tracking
# SENTRY_DSN=https://xxx@sentry.io/yyy
SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry — leave empty to disable trace export
# OTEL_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_SERVICE_NAME=transcript-intelligence
