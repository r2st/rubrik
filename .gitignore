# Generated artifacts (commit a .gitkeep instead — see output/.gitkeep)
output/*
!output/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.nbconvert.ipynb
_executed.ipynb

# Streamlit
.streamlit/secrets.toml

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Coverage & build
htmlcov/
.coverage
coverage.xml
*.egg-info/
build/
dist/

# Local env (never commit secrets — see .env.example)
.env
.env.local
.env.*.local

# Runtime logs from start-all.sh
.run-logs/

# Gemma 4 LoRA adapter weights (too big for git — see gemma-finetune/README.md
# for reproduction instructions)
gemma-finetune/adapters/**/*.safetensors
gemma-finetune/adapters/**/*.bin
gemma-finetune/adapters/**/*.pt
gemma-finetune/adapters/**/optimizer.pt
gemma-finetune/adapters/**/*-trainer/
