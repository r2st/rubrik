    {
      "id": 1,
      "title": "p95 request latency (s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket{job=\"transcript-intel-api\"}[5m])))",
          "legendFormat": "p95 · {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.4},
              {"color": "red", "value": 0.8}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "5xx rate (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{job=\"transcript-intel-api\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx · {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 3,
