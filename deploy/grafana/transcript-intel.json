      "datasource": {"type": "prometheus", "uid": "prom"},
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{job=\"transcript-intel-api\", status=~\"5..\"}[1h])) / sum(rate(http_requests_total{job=\"transcript-intel-api\"}[1h]))) / 0.001",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 6},
              {"color": "red", "value": 14.4}
            ]
          }
        }
      }
    },
